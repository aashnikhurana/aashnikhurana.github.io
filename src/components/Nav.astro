<!-- Mobile full-screen overlay -->
<div
  id="nav-overlay"
  style="display: none; position: fixed; inset: 0; z-index: 49; background: rgba(14, 14, 16, 0.75); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); flex-direction: column; align-items: center; justify-content: center; gap: 40px;"
  aria-hidden="true"
>
  <nav style="display: flex; flex-direction: column; align-items: center; gap: 32px; list-style: none;" aria-label="Mobile navigation">
    <a href="/#research" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); text-decoration: none;">Research</a>
    <a href="/#beyond-bench" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); text-decoration: none;">Beyond Bench</a>
    <a href="/#publications" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); text-decoration: none;">Publications</a>
    <a href="/#about" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); text-decoration: none;">About</a>
    <a href="/resume/AashniKhurana_Resume.pdf" target="_blank" rel="noopener noreferrer" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); text-decoration: none;">Resume</a>
  </nav>
</div>

<style>
  @media (max-width: 1024px) {
    .nav-desktop-links { display: none !important; }
    .nav-mobile-btn { display: flex !important; }
    .site-nav-container {
      padding: 16px 24px !important;
    }
    .wordmark-link {
      font-size: 15px !important;
      letter-spacing: 0.12em !important;
      white-space: nowrap !important;
    }
  }
  /* Restore desktop nav for 1024x600 miniature desktop */
  @media (width: 1024px) and (height: 600px) {
    .nav-desktop-links { display: flex !important; }
    .nav-mobile-btn { display: none !important; }
  }
  @media (min-width: 1025px) {
    .nav-mobile-btn { display: none !important; }
  }

  /* Hamburger Animation */
  .hamburger-line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.2px;
    background-color: #FFFFFF;
    transition: all 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hamburger-line.top { top: 0; }
  .hamburger-line.mid { top: 4px; }
  .hamburger-line.bot { top: 8px; }

  #nav-hamburger.active .hamburger-line.top {
    transform: translateY(4px) rotate(45deg);
  }
  #nav-hamburger.active .hamburger-line.mid {
    opacity: 0;
    transform: translateX(10px);
  }
  #nav-hamburger.active .hamburger-line.bot {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Conditional Home Link */
  .home-nav-item {
    width: 0;
    opacity: 0;
    visibility: hidden;
    overflow: hidden;
    transition: all 500ms var(--easing);
    margin-right: -32px; /* Offset the gap when hidden */
  }

  #site-nav.scrolled .home-nav-item {
    width: 45px;
    opacity: 1;
    visibility: visible;
    margin-right: 0;
  }

  #site-nav.scrolled {
    padding-top: 16px !important;
    padding-bottom: 16px !important;
    background: rgba(0, 0, 0, 0.7) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-overlay-link {
    transition: color 400ms cubic-bezier(0.2, 0, 0, 1);
  }
  .nav-overlay-link:hover {
    color: var(--accent) !important;
  }
</style>

<script>
  const nav = document.getElementById('site-nav')
  const overlay = document.getElementById('nav-overlay')
  const hamburger = document.getElementById('nav-hamburger')

  let isOpen = false

  function toggleMenu() {
    isOpen = !isOpen
    if (isOpen) {
      overlay.style.display = 'flex'
      overlay.setAttribute('aria-hidden', 'false')
      hamburger?.setAttribute('aria-expanded', 'true')
      hamburger?.classList.add('active')
      document.body.style.overflow = 'hidden'
    } else {
      overlay.style.display = 'none'
      overlay.setAttribute('aria-hidden', 'true')
      hamburger?.setAttribute('aria-expanded', 'false')
      hamburger?.classList.remove('active')
      document.body.style.overflow = ''
    }
  }

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled')
    } else {
      nav?.classList.remove('scrolled')
    }
  }, { passive: true })

  hamburger?.addEventListener('click', toggleMenu)

  // Close overlay when clicking a link
  overlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (isOpen) toggleMenu()
    })
  })

  // Close on backdrop click (clicking outside the nav links)
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay && isOpen) toggleMenu()
  })

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) toggleMenu()
  })
</script>
