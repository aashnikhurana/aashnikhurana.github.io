<nav
  id="site-nav"
  style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 24px 7vw; transition: all 400ms cubic-bezier(0.2, 0, 0, 1);"
  aria-label="Site navigation"
>
  <div style="display: flex; align-items: center; justify-content: space-between;">
    <div
      id="nav-wordmark"
      style="display: flex; align-items: center; height: 40px; border-radius: 999px; border: 1px solid transparent; transition: all 400ms cubic-bezier(0.2, 0, 0, 1);"
    >
      <a
        href="/"
        style="font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: #FFFFFF; text-decoration: none; padding: 0 24px; transition: padding 400ms var(--easing);"
        class="wordmark-link"
      >
        AASHNI KHURANA
      </a>
    </div>

    <ul
      id="nav-links"
      style="display: flex; align-items: center; gap: 32px; list-style: none; margin: 0; padding: 0; height: 40px; border-radius: 999px; border: 1px solid transparent; transition: all 400ms cubic-bezier(0.2, 0, 0, 1);"
      class="nav-desktop-links"
    >
      <li style="padding-left: 24px; transition: padding 400ms var(--easing);" class="pill-first-li">
        <a href="/#research" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #FFFFFF; text-decoration: none;" class="hover-underline nav-link">Research</a>
      </li>

      <li>
        <a href="/#about" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #FFFFFF; text-decoration: none;" class="hover-underline nav-link">About</a>
      </li>

      <li>
        <a href="/#contact" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #FFFFFF; text-decoration: none;" class="hover-underline nav-link">Contact</a>
      </li>

      <li style="padding-right: 24px; transition: padding 400ms var(--easing);" class="pill-last-li">
        <a href="/cv/aashni-khurana-cv.pdf" target="_blank" rel="noopener noreferrer" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #FFFFFF; text-decoration: none;" class="hover-underline nav-link">CV</a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="nav-hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      style="display: none; background: none; border: none; cursor: pointer; padding: 4px; color: var(--text-muted);"
      class="nav-mobile-btn"
    >
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile full-screen overlay -->
<div
  id="nav-overlay"
  style="display: none; position: fixed; inset: 0; z-index: 49; background: rgba(14, 14, 16, 0.97); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); flex-direction: column; align-items: center; justify-content: center; gap: 40px;"
  aria-hidden="true"
>
  <button
    id="nav-close"
    aria-label="Close menu"
    style="position: absolute; top: 24px; right: 7vw; background: none; border: none; cursor: pointer; color: var(--text-muted); padding: 8px;"
  >
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" d="M18 6L6 18M6 6l12 12" />
    </svg>
  </button>
  <nav style="display: flex; flex-direction: column; align-items: center; gap: 32px; list-style: none;" aria-label="Mobile navigation">
    <a href="/#research" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 32px; color: var(--text); text-decoration: none;">Research</a>
    <a href="/#about" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 32px; color: var(--text); text-decoration: none;">About</a>
    <a href="/#contact" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 32px; color: var(--text); text-decoration: none;">Contact</a>
    <a href="/cv/aashni-khurana-cv.pdf" target="_blank" rel="noopener noreferrer" class="nav-overlay-link" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 32px; color: var(--text); text-decoration: none;">CV</a>
  </nav>
</div>

<style>
  @media (max-width: 767px) {
    .nav-desktop-links { display: none !important; }
    .nav-mobile-btn { display: flex !important; }
  }
  @media (min-width: 768px) {
    .nav-mobile-btn { display: none !important; }
  }

  /* Scrolled state for the pill */
  #site-nav.scrolled {
    padding-top: 16px !important;
    padding-bottom: 16px !important;
  }

  #site-nav.scrolled #nav-links,
  #site-nav.scrolled #nav-wordmark {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  /* Adjust padding when it becomes a pill */
  #site-nav:not(.scrolled) .pill-first-li { padding-left: 0 !important; }
  #site-nav:not(.scrolled) .pill-last-li { padding-right: 0 !important; }
  #site-nav:not(.scrolled) .wordmark-link { padding-left: 0 !important; padding-right: 0 !important; }

  .nav-overlay-link {
    transition: color 400ms cubic-bezier(0.2, 0, 0, 1);
  }
  .nav-overlay-link:hover {
    color: var(--accent) !important;
  }
</style>

<script>
  const nav = document.getElementById('site-nav')
  const overlay = document.getElementById('nav-overlay')
  const hamburger = document.getElementById('nav-hamburger')
  const closeBtn = document.getElementById('nav-close')




  function openOverlay() {
    if (!overlay) return
    overlay.style.display = 'flex'
    overlay.setAttribute('aria-hidden', 'false')
    hamburger?.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  }

  function closeOverlay() {
    if (!overlay) return
    overlay.style.display = 'none'
    overlay.setAttribute('aria-hidden', 'true')
    hamburger?.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled')
    } else {
      nav?.classList.remove('scrolled')
    }
  }, { passive: true })

  hamburger?.addEventListener('click', openOverlay)
  closeBtn?.addEventListener('click', closeOverlay)

  // Close overlay when clicking a link
  overlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeOverlay)
  })

  // Close on backdrop click (clicking outside the nav links)
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeOverlay()
  })

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeOverlay()
  })
</script>
