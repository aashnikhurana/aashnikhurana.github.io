---
import { contact } from '@/data/content'
---

<footer style="border-top: 1px solid var(--rule); margin-top: 0;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 48px 7vw; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px;">
    <!-- Left: copyright -->
    <span style="font-family: Inter, sans-serif; font-size: 13px; color: var(--text-muted);">
      &copy; 2026 Aashni Khurana
    </span>

    <!-- Center: built with -->
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-muted);">
      Built with Astro &middot; Hosted on GitHub Pages
    </span>

    <!-- Right: social icons -->
    <div style="display: flex; align-items: center; gap: 8px;">
      <!-- LinkedIn -->
      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="footer-icon"
        style="color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="3" />
          <path d="M7 10v7M7 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 10v7" />
        </svg>
      </a>

      <!-- GitHub -->
      <a
        href={contact.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="footer-icon"
        style="color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
        </svg>
      </a>

      <!-- Email -->
      <a
        href={`mailto:${contact.email}`}
        aria-label="Email"
        class="footer-icon"
        style="color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-icon:hover {
    color: var(--accent) !important;
  }
</style>
