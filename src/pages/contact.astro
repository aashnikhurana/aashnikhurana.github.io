---
import Base from '@/layouts/Base.astro'
---

<Base
  title="Contact"
  description="Contact Aashni Khurana — for research, collaboration, or a conversation."
>

  <div style="max-width: 960px; margin: 0 auto; padding: 80px 7vw 120px;">

    <h1 style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(40px, 6vw, 64px); color: var(--text); line-height: 1.1; margin: 0 0 24px;">
      Contact
    </h1>

    <p style="font-family: Inter, sans-serif; font-size: 18px; color: var(--text-muted); line-height: 1.6; margin: 0 0 64px;">
      For research, collaboration, or a conversation.
    </p>

    <div>

      <div style="display: flex; gap: 24px; align-items: baseline; padding: 20px 0; border-top: 1px solid var(--rule);">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); min-width: 120px; flex-shrink: 0;">Email</span>
        <a href="mailto:khurana.aashni1101@gmail.com" style="font-family: Inter, sans-serif; font-size: 16px; color: var(--text); text-decoration: none; transition: color 300ms cubic-bezier(0.2, 0, 0, 1);" class="contact-link">
          khurana.aashni1101@gmail.com
        </a>
      </div>

      <div style="display: flex; gap: 24px; align-items: baseline; padding: 20px 0; border-top: 1px solid var(--rule);">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); min-width: 120px; flex-shrink: 0;">LinkedIn</span>
        <a href="https://linkedin.com/in/aashni-khurana" target="_blank" rel="noopener noreferrer" style="font-family: Inter, sans-serif; font-size: 16px; color: var(--text); text-decoration: none; transition: color 300ms cubic-bezier(0.2, 0, 0, 1);" class="contact-link">
          linkedin.com/in/aashni-khurana
        </a>
      </div>

      <div style="display: flex; gap: 24px; align-items: baseline; padding: 20px 0; border-top: 1px solid var(--rule);">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); min-width: 120px; flex-shrink: 0;">GitHub</span>
        <a href="https://github.com/aashnikhurana" target="_blank" rel="noopener noreferrer" style="font-family: Inter, sans-serif; font-size: 16px; color: var(--text); text-decoration: none; transition: color 300ms cubic-bezier(0.2, 0, 0, 1);" class="contact-link">
          github.com/aashnikhurana
        </a>
      </div>

      <div style="display: flex; gap: 24px; align-items: baseline; padding: 20px 0; border-top: 1px solid var(--rule);">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); min-width: 120px; flex-shrink: 0;">ORCID</span>
        <!-- TODO: Aashni — replace with ORCID link when available -->
        <span style="font-family: Inter, sans-serif; font-size: 16px; color: var(--text-muted);">TODO</span>
      </div>

      <div style="display: flex; gap: 24px; align-items: baseline; padding: 20px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); min-width: 120px; flex-shrink: 0;">Google Scholar</span>
        <!-- TODO: Aashni — replace with Google Scholar link when available -->
        <span style="font-family: Inter, sans-serif; font-size: 16px; color: var(--text-muted);">TODO</span>
      </div>

    </div>

  </div>

</Base>

<style>
  .contact-link:hover {
    color: var(--accent) !important;
  }
</style>
