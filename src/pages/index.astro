---
import Base from '@/layouts/Base.astro'
---

<Base
  title="Home"
  description="I design and validate bioanalytical assays for molecules that resist standard methods. Research Scientist at UC San Diego Health."
>

  <!-- ── HERO ── -->
  <section
    id="hero"
    style="min-height: 100vh; position: relative; display: flex; align-items: center; padding: 0 7vw;"
  >
    <!-- Top-left wordmark -->
    <div style="position: absolute; top: 5vh; left: 7vw; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted);" aria-hidden="true">
      AASHNI KHURANA
    </div>

    <!-- 60/40 split: text left, image right -->
    <div class="hero-inner" style="display: grid; grid-template-columns: 60fr 40fr; gap: 0; align-items: center; width: 100%; max-width: 1400px; margin: 0 auto;">

      <!-- Left: headline + subtitle + CTA -->
      <div style="padding-right: 6vw;">
        <h1 class="hero-headline" style="margin: 0; padding: 0;">
          <span
            class="animate-fade-rise"
            style="display: block; font-family: Inter, sans-serif; font-weight: 700; font-size: clamp(48px, 6vw, 96px); color: var(--text); line-height: 1.05;"
          >
            I turn molecules
          </span>
          <span
            class="animate-fade-rise-d200"
            style="display: block; font-family: Inter, sans-serif; font-weight: 700; font-size: clamp(48px, 6vw, 96px); color: var(--text); line-height: 1.05;"
          >
            into&nbsp;<span
              class="data-word"
              style="font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--accent); text-shadow: 0 0 30px var(--accent-glow);"
            >data.</span>
          </span>
        </h1>

        <p
          class="animate-fade-rise-d400"
          style="font-family: Inter, sans-serif; font-weight: 400; font-size: 18px; color: var(--text-muted); line-height: 1.6; max-width: 520px; margin-top: 24px; margin-bottom: 0;"
        >
          Analytical chemistry &middot; Bioanalytical methods &middot; AI for science<br />
          Currently at UC San Diego Health &middot; Based in San Diego
        </p>

        <div class="animate-fade-rise-d600" style="margin-top: 32px;">
          <a
            href="#case-studies"
            class="cta-link arrow-nudge"
            style="font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 20px; color: var(--accent); text-decoration: none; display: inline-flex; align-items: center; gap: 4px;"
          >
            <span class="hover-underline" style="text-underline-offset: 6px; text-decoration-thickness: 1px;">Read the research</span>&nbsp;<span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Right: rotating albumin image -->
      <div class="hero-image-col" style="position: relative; display: flex; align-items: center; justify-content: center;">
        <div style="position: relative; width: 40vw; max-width: 520px;">
          <!-- 3D Interactive Model -->
          <div
            style="width: 100%; aspect-ratio: 1; border-radius: 50%; overflow: hidden; mask-image: radial-gradient(ellipse at center, black 55%, transparent 90%); -webkit-mask-image: radial-gradient(ellipse at center, black 55%, transparent 90%); filter: brightness(0.85) saturate(1.1); cursor: grab;"
          >
            <div 
              style="width: 100%; height: 100%; position: relative;"
              class="viewer_3Dmoljs"
              data-pdb="1ao6"
              data-backgroundcolor="#0E0E10"
              data-style="cartoon:color=#c583ab"
            ></div>
            <script is:inline src="https://3Dmol.org/build/3Dmol-min.js"></script>
          </div>

          <!-- Image caption — does NOT rotate -->
          <p style="position: absolute; bottom: -28px; left: 0; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); white-space: nowrap;">
            HUMAN SERUM ALBUMIN &middot; DMTS BINDING POSE &middot; PYMOL
          </p>
        </div>
      </div>
    </div>

    <!-- Scroll cue — outer div handles centering, inner handles bob animation -->
    <div
      style="position: absolute; bottom: 5vh; left: 50%; transform: translateX(-50%); pointer-events: none;"
      aria-hidden="true"
    >
      <div
        class="scroll-bob"
        style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-muted); text-align: center; white-space: nowrap;"
      >
        &darr; scroll
      </div>
    </div>

    <!-- Sentinel: nav IntersectionObserver watches this -->
    <div id="hero-sentinel" style="position: absolute; bottom: 0; left: 0; width: 100%; height: 1px; pointer-events: none;" aria-hidden="true"></div>
  </section>


  <!-- ── PROTEIN RIBBON TRANSITION BAND ── -->
  <div style="height: 120px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px;">
    <p style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--text-muted); margin: 0;">
      SELECTED RESEARCH &mdash; CHRONOLOGICAL
    </p>
    <div style="width: 120px; height: 1px; background: var(--accent); opacity: 0.2;"></div>
  </div>


  <!-- ── CASE STUDY CARDS ── -->
  <section id="case-studies" style="max-width: 960px; margin: 0 auto; padding: 0 7vw 120px;">

    <!-- Card 1: Anant -->
    <a href="/case-studies/anant" class="case-card" style="display: grid; grid-template-columns: 120px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1);">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px;">
        2022 &mdash; 2023
      </span>
      <div>
        <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; max-width: 560px; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          Analytical Method Development in cGMP Manufacturing
        </h2>
        <p style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; max-width: 560px; margin: 0 0 20px;">
          Ran analytical QC and method validation on 50+ batches per week across eight drug substance programs — including two HPLC methods validated to ICH Q2(R1) and two FDA audit-readiness reviews with zero critical findings.
        </p>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
          cGMP &middot; HPLC / GC-FID &middot; Method Validation &middot; FDA Audit Readiness
        </div>
      </div>
      <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
        <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          Read <span class="arrow">&rarr;</span>
        </span>
      </div>
    </a>

    <!-- Card 2: DMDS Experimental -->
    <a href="/case-studies/dmds-experimental" class="case-card" style="display: grid; grid-template-columns: 120px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1); margin-top: 96px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px;">
        2023 &mdash; 2025
      </span>
      <div>
        <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; max-width: 560px; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          DMDS&ndash;Albumin Protein Binding
        </h2>
        <p style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; max-width: 560px; margin: 0 0 20px;">
          Designed a vapor-phase binding assay for a volatile cyanide-antidote metabolite. Turned DMDS&rsquo;s instability from the thing that breaks the measurement into the thing that makes it work.
        </p>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
          Assay Design &middot; Bioanalytical Methods &middot; ADME/DMPK
        </div>
      </div>
      <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
        <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          Read <span class="arrow">&rarr;</span>
        </span>
      </div>
    </a>

    <!-- Card 3: DMDS Computational -->
    <a href="/case-studies/dmds-computational" class="case-card" style="display: grid; grid-template-columns: 120px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1); margin-top: 96px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px;">
        2023 &mdash; 2025
      </span>
      <div>
        <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; max-width: 560px; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          Computational Protein Binding of DMTS and DMDS
        </h2>
        <p style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; max-width: 560px; margin: 0 0 20px;">
          In-silico companion to the wet-lab binding study &mdash; blind-docked DMTS and DMDS against bovine serum albumin to map candidate binding sites and corroborate weak-affinity findings observed experimentally.
        </p>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
          Molecular Docking &middot; AutoDock Vina &middot; PyMOL &middot; In Silico
        </div>
      </div>
      <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
        <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          Read <span class="arrow">&rarr;</span>
        </span>
      </div>
    </a>

    <!-- Card 4: iPSC -->
    <a href="/case-studies/ipsc-meditation" class="case-card" style="display: grid; grid-template-columns: 120px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1); margin-top: 96px;">
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px;">
        2025 &mdash; PRESENT
      </span>
      <div>
        <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; max-width: 560px; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          iPSC-Derived Motor Neurons as a Model for Meditation-Induced Bloodborne Signaling
        </h2>
        <p style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; max-width: 560px; margin: 0 0 20px;">
          Building a human motor neuron model to decode how meditation-induced bloodborne factors reshape neuronal bioenergetics &mdash; the next-generation cellular system for a published research program moving from neuroblastoma cell lines to patient-derivable neurons.
        </p>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
          iPSC &middot; Bioanalytical Assay Development &middot; Neurotherapeutics
        </div>
      </div>
      <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
        <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
          Read <span class="arrow">&rarr;</span>
        </span>
      </div>
    </a>

  </section>


  <!-- ── BIO BLURB ── -->
  <section style="max-width: 960px; margin: 0 auto; padding: 0 7vw 120px; text-align: center;">
    <p style="font-family: Inter, sans-serif; font-weight: 400; font-size: 17px; line-height: 1.7; color: var(--text); max-width: 60ch; margin: 0 auto 32px;">
      I design and validate bioanalytical assays for molecules that resist standard methods &mdash; volatile drug candidates, stem-cell-derived neurons, and the noisy biological signals that carry information between them. My work spans regulated cGMP manufacturing, academic wet-lab research, in-silico molecular modeling, and emerging human neural models. I&rsquo;m currently a Research Scientist at UC San Diego Health exploring how bloodborne factors reshape neuronal bioenergetics.
    </p>
    <div style="display: flex; align-items: center; justify-content: center; gap: 16px;">
      <a
        href="/about"
        class="arrow-nudge hover-underline"
        style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);"
      >
        ABOUT <span class="arrow">&rarr;</span>
      </a>
      <span style="color: var(--text-muted); font-size: 12px;">&middot;</span>
      <a
        href="/contact"
        class="arrow-nudge hover-underline"
        style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);"
      >
        CONTACT <span class="arrow">&rarr;</span>
      </a>
    </div>
  </section>

</Base>

<style>
  /* Card hover: title accent + rule highlight */
  .case-card:hover .card-title {
    color: var(--accent) !important;
  }

  .case-card:hover {
    border-top-color: rgba(155, 58, 74, 0.3) !important;
  }

  .case-card:hover .card-read {
    color: var(--accent) !important;
  }

  /* Mobile: stack hero vertically, image first */
  @media (max-width: 767px) {
    .hero-inner {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto auto;
      gap: 48px !important;
    }

    .hero-image-col {
      order: -1;
    }

    .hero-image-col > div {
      width: 60vw !important;
      max-width: 60vw !important;
    }

    /* Case study cards: single column on mobile */
    .case-card {
      grid-template-columns: 1fr !important;
      gap: 16px 0 !important;
    }

    .case-card > div:last-child {
      justify-content: flex-start !important;
    }
  }

  /* Bio links hover */
  .hover-underline:hover {
    color: var(--accent) !important;
  }
</style>
