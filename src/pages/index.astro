---
import Base from '@/layouts/Base.astro'
import headshot from '../headshot.jpg'
---

<Base
  title="Home"
  description="I design and validate bioanalytical assays for molecules that resist standard methods. Research Scientist at UC San Diego Health."
>

  <!-- ── HERO ── -->
  <section
    id="hero"
    style="width: 70%; max-width: 1080px; margin: 0 auto; min-height: 100vh; position: relative; display: flex; align-items: center;"
  >


    <!-- 60/40 split: text left, image right -->
    <div class="hero-inner" style="display: grid; grid-template-columns: 75fr 25fr; gap: 0; align-items: center; width: 100%; max-width: 1080px; margin: 0 auto;">

      <!-- Left: headline + subtitle + CTA -->
      <div style="padding-right: 4vw;">
        <h1 class="hero-headline" style="margin: 0; padding: 0;">
          <span
            class="animate-fade-rise"
            style="display: block; font-family: Inter, sans-serif; font-weight: 700; font-size: clamp(48px, 6vw, 96px); color: var(--text); line-height: 1.05;"
          >
            I turn
          </span>
          <span
            class="animate-fade-rise-d200"
            style="display: block; font-family: Inter, sans-serif; font-weight: 700; font-size: clamp(48px, 6vw, 96px); color: var(--text); line-height: 1.05;"
          >
            <span class="glow-word molecule-word">molecules</span>
          </span>
          <span
            class="animate-fade-rise-d400"
            style="display: block; font-family: Inter, sans-serif; font-weight: 700; font-size: clamp(48px, 6vw, 96px); color: var(--text); line-height: 1.05;"
          >
            into&nbsp;<span
              class="glow-word data-word"
              style="font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; color: var(--accent);"
            >data.</span>
          </span>
        </h1>

        <div
          class="animate-fade-rise-d600"
          style="font-family: Inter, sans-serif; font-weight: 400; font-size: 18px; color: var(--text-muted); line-height: 1.6; margin-top: 24px; margin-bottom: 0;"
        >
          <div style="white-space: nowrap;">Bioanalytical chemistry &middot; Method development &middot; Drug discovery</div>
          <div style="margin-top: 12px; letter-spacing: 0.02em;">
            Based in San Diego &middot; <span style="color: var(--accent);">Open to work</span>
          </div>
        </div>


      </div>

      <!-- Right: rotating albumin image -->
      <div class="hero-image-col" style="position: relative; display: flex; align-items: center; justify-content: center;">
        <div style="position: relative; width: 40vw; max-width: 520px;">
          <!-- 3D Interactive Model -->
          <div
            style="width: 100%; aspect-ratio: 1; border-radius: 50%; overflow: hidden; mask-image: radial-gradient(ellipse at center, black 55%, transparent 90%); -webkit-mask-image: radial-gradient(ellipse at center, black 55%, transparent 90%); filter: brightness(0.85) saturate(1.1); cursor: grab;"
          >
            <div 
              id="albumin-viewer"
              style="width: 100%; height: 100%; position: relative;"
            ></div>
            <script is:inline src="https://3Dmol.org/build/3Dmol-min.js"></script>
            <script is:inline>
              document.addEventListener('DOMContentLoaded', () => {
                const element = document.getElementById('albumin-viewer');
                const config = { backgroundColor: '#000000' };
                const viewer = $3Dmol.createViewer(element, config);
                
                $3Dmol.download("pdb:1ao6", viewer, {}, () => {
                  viewer.setStyle({}, { cartoon: { color: '#D57F8F' } });
                  viewer.zoomTo();
                  viewer.render();
                  
                  // Start slow rotation
                  let angle = 0;
                  function animate() {
                    viewer.rotate(0.1, 'y'); // Rotate 0.1 degrees per frame around Y axis
                    viewer.render();
                    requestAnimationFrame(animate);
                  }
                  animate();
                });
              });
            </script>
          </div>


        </div>
      </div>
    </div>

    <!-- Scroll cue — outer div handles centering, inner handles bob animation -->
    <div
      style="position: absolute; bottom: 5vh; left: 50%; transform: translateX(-50%); pointer-events: none;"
      aria-hidden="true"
    >
      <div
        class="scroll-bob"
        style="color: var(--text-muted); display: flex; justify-content: center; filter: drop-shadow(0 0 8px rgba(237, 234, 227, 0.4));"
      >
        <svg width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 2L10 10L18 2" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>


  </section>


  <!-- ── RESEARCH ── -->
  <section id="research" style="width: 70%; max-width: 1080px; margin: 0 auto; padding: 120px 0 80px;">
    <h1 class="section-heading" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(32px, 4vw, 42px); color: var(--text); line-height: 1.1; margin: 0 0 20px;">
      Research
    </h1>
    <p
      style="font-family: Inter, sans-serif; font-size: 18px; color: var(--text-muted); line-height: 1.7; margin: 0 0 64px;"
    >
      Four projects over four years. A trajectory from cGMP analytical QC, through academic wet-lab and computational binding studies, to emerging human neuronal models. The unifying thread is method development: building, validating, and documenting the assays that let a team ask sharper questions.
    </p>



    <!-- Case Study Cards -->
    <div class="case-studies-list">
      <!-- Card 1: iPSC (UCSD) -->
      <a href="/case-studies/ipsc-meditation" class="case-card" style="display: grid; grid-template-columns: 180px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1);">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px; white-space: nowrap;">
          Aug '25 &mdash; Present
        </span>
        <div>
          <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            iPSC-Derived Motor Neurons as a Model for Meditation-Induced Bloodborne Signaling
          </h2>
          <p
            style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; margin: 0 0 20px;"
          >
            Building an iPSC-derived motor neuron platform to study how meditation-induced plasma factors reshape neuronal bioenergetics, the next-generation human cellular model for Dr. Hemal Patel's research program at UCSD. Running the full differentiation protocol and developing a NanoSight NTA and Bradford bioanalytical pipeline to test pre- and post-meditation plasma.
          </p>
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
            iPSC &middot; MOTOR NEURON DIFFERENTIATION &middot; NANOSIGHT NTA &middot; BIOANALYTICAL ASSAY DEVELOPMENT &middot; NEUROTHERAPEUTICS &middot; EXTRACELLULAR VESICLES
          </div>
        </div>
        <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
          <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            Read <span class="arrow">&rarr;</span>
          </span>
        </div>
      </a>

      <!-- Card 2: DMDS Computational (SHSU) -->
      <a href="/case-studies/dmds-computational" class="case-card" style="display: grid; grid-template-columns: 180px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1); margin-top: 64px;">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px; white-space: nowrap;">
          Aug '23 &mdash; May '25
        </span>
        <div>
          <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            Computational Protein Binding of DMTS and DMDS
          </h2>
          <p
            style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; margin: 0 0 20px;"
          >
            Ran blind molecular docking of DMTS and DMDS against bovine serum albumin in AutoDock Vina to corroborate wet-lab binding data. Best-pose affinities (−2.6 / −2.3 kcal/mol) aligned with VTE and RED results, and shared binding geometries suggested a common transport mechanism for the parent compound and its active metabolite.
          </p>
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
            MOLECULAR DOCKING &middot; AUTODOCK VINA &middot; PYMOL &middot; PROTEIN BINDING &middot; PK MODELING
          </div>
        </div>
        <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
          <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            Read <span class="arrow">&rarr;</span>
          </span>
        </div>
      </a>

      <!-- Card 3: DMDS Experimental (SHSU) -->
      <a href="/case-studies/dmds-experimental" class="case-card" style="display: grid; grid-template-columns: 180px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1); margin-top: 64px;">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px; white-space: nowrap;">
          Aug '23 &mdash; May '25
        </span>
        <div>
          <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            DMDS&ndash;Albumin Protein Binding
          </h2>
          <p
            style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; margin: 0 0 20px;"
          >
            Developed a vapor-phase protein binding assay (VTE) and a validated HPLC-UV method per ICH Q2(R1) to characterize how a volatile cyanide-antidote metabolite binds to human serum albumin. Triangulated with Rapid Equilibrium Dialysis (RED), diagnosed a 25% signal loss as surface partitioning rather than biology, and redesigned the RED plate seal to fix it.
          </p>
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
            VTE &middot; RED &middot; PROTEIN BINDING &middot; HPLC METHOD VALIDATION &middot; ADME/DMPK
          </div>
        </div>
        <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
          <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            Read <span class="arrow">&rarr;</span>
          </span>
        </div>
      </a>

      

      <!-- Card 4: Anant (Bottom) -->
      <a href="/case-studies/anant" class="case-card" style="display: grid; grid-template-columns: 180px 1fr 140px; gap: 0 32px; align-items: start; text-decoration: none; padding: 40px 0; border-top: 1px solid var(--rule); transition: border-color 400ms cubic-bezier(0.2, 0, 0, 1); margin-top: 64px;">
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); padding-top: 6px; white-space: nowrap;">
          May '22 &mdash; May '23
        </span>
        <div>
          <h2 class="card-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(22px, 2.5vw, 32px); color: var(--text); line-height: 1.2; margin: 0 0 12px; transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            Analytical Method Development in cGMP Manufacturing
          </h2>
          <p
            style="font-family: Inter, sans-serif; font-weight: 400; font-size: 15px; color: var(--text-muted); line-height: 1.55; margin: 0 0 20px;"
          >
            Ran cGMP batch-release testing on 50+ API batches/week using HPLC-UV/Vis and GC-FID, generated 600+ Certificates of Analysis, and validated two RP-HPLC methods per ICH Q2(R1). Supported two FDA audit-readiness reviews that closed with zero critical findings.
          </p>
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
            cGMP &middot; HPLC &middot; GC-FID &middot; METHOD VALIDATION &middot; FDA AUDIT READINESS &middot; ICH Q2(R1)
          </div>
        </div>
        <div style="display: flex; justify-content: flex-end; padding-top: 6px;">
          <span class="card-read arrow-nudge" style="font-family: Inter, sans-serif; font-size: 14px; font-style: italic; color: var(--text-muted); transition: color 400ms cubic-bezier(0.2, 0, 0, 1);">
            Read <span class="arrow">&rarr;</span>
          </span>
        </div>
      </a>
    </div>
  </section>
  <!-- ── BEYOND BENCH ── -->
  <section id="beyond-bench" style="width: 70%; max-width: 1080px; margin: 0 auto; padding: 60px 0 80px; scroll-margin-top: 70px;">
    <h1 class="section-heading" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(32px, 4vw, 42px); color: var(--text); line-height: 1.1; margin: 0 0 60px;">
      Beyond Bench
    </h1>

    <!-- Subheading: Training & Internships -->
    <div style="display: flex; align-items: center; gap: 12px; margin: 0 0 40px;">
      <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; fill: var(--accent); filter: drop-shadow(0 0 3px var(--accent)) drop-shadow(0 0 8px var(--accent)); flex-shrink: 0;">
        <path d="M12 0c.5 6 1 11 12 12-11 1-11.5 6-12 12-.5-6-1-11-12-12 11-1 11.5-6 12-12z" />
      </svg>
      <h2 class="section-heading" style="font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text); margin: 0;">
        Training & Internships
      </h2>
    </div>

    <div class="training-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      <!-- Card 1: BISR -->
      <div class="training-card" data-modal="modal-bisr">
        <h3 style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); margin: 0;">
          Research and Development Intern
        </h3>
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.2em; margin: 0;">
          Birla Institute of Scientific Research
          <span style="display: block; margin-top: 6px; font-size: 12px; opacity: 0.8;">Summer '23</span>
        </p>
      </div>

      <!-- Card 2: Hungary -->
      <div class="training-card" data-modal="modal-hungary">
        <h3 style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 24px; color: var(--text); margin: 0;">
          Study Abroad Program
        </h3>
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.2em; margin: 0;">
          Chemical Imagination in Hungary
          <span style="display: block; margin-top: 6px; font-size: 12px; opacity: 0.8;">May '24</span>
        </p>
      </div>
    </div>

  <!-- Modals -->
  <div id="modal-bisr" class="training-modal">
    <div class="modal-content">
      <button class="close-modal">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 40px; margin-bottom: 60px;">
        <div style="flex: 1;">
          <h2 class="section-heading" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(32px, 4vw, 42px); color: var(--text); line-height: 1.1; margin: 0 0 12px;">
            Research and Development Intern
          </h2>
          <p style="font-family: Inter, sans-serif; font-style: italic; font-size: 17px; color: var(--text-muted); margin: 0; line-height: 1.5;">
            Birla Institute of Scientific Research &middot; Jaipur &middot; Summer '23
          </p>
          <p style="font-family: Inter, sans-serif; font-size: 15px; color: var(--text-muted); margin: 8px 0 0;">
            Advisor: <a href="https://bisr.res.in/profile_sampat.php" target="_blank" rel="noopener noreferrer" class="hover-underline" style="color: inherit; text-decoration: none; font-style: normal;">Dr. Sampat Nehra <span style="display: inline-block; position: relative; top: 2px;">&nearr;</span></a>
          </p>
        </div>
        <img 
          src="/images/logos/Birla-logo.png" 
          alt="BISR Logo" 
          style="height: 85px; width: auto; object-fit: contain; opacity: 0.9; filter: brightness(1.2) contrast(1.1);"
        />
      </div>

      <div style="font-family: Inter, sans-serif; font-size: 17px; color: var(--text-muted); line-height: 1.7; display: flex; flex-direction: column; gap: 20px;">
        <p>Before starting my MS, I spent a summer at BISR in Jaipur doing a crash course in the biological side of chemistry. The work spanned microbiology, molecular biology, fermentation, protein extraction, bioinformatics, and early-stage computational drug design, with hands-on time on the equipment and software that underlies each.</p>
        <p>BISR is where my foundation in the biological sciences actually starts, and it is the bridge between my undergraduate chemistry training and the iPSC and protein-binding work that came later.</p>
      </div>
    </div>
  </div>

  <div id="modal-hungary" class="training-modal">
    <div class="modal-content">
      <button class="close-modal">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      
      <div style="margin-bottom: 60px;">
        <h2 class="section-heading" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(32px, 4vw, 42px); color: var(--text); line-height: 1.1; margin: 0 0 12px;">
          Chemical Imagination and Innovation in Hungary
        </h2>
        <p style="font-family: Inter, sans-serif; font-style: italic; font-size: 17px; color: var(--text-muted); margin: 0; line-height: 1.5;">
          May '24
        </p>
      </div>

      <div style="font-family: Inter, sans-serif; font-size: 17px; color: var(--text-muted); line-height: 1.7; display: flex; flex-direction: column; gap: 24px;">
        <p>In May 2024 I joined a six-institution study-abroad program across Hungary, funded by SHSU's College of Science and Engineering Technology and the Bearkat Abroad Scholarship. The program was an intensive survey of how chemistry is practiced in different contexts:</p>
        
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 20px;">
          {[
            { site: 'Biological Research Centre (Szeged)', desc: 'Biophysical chemistry, drug transport, and Vitamin C research in the institute with a direct lineage to Albert Szent-Györgyi.' },
            { site: 'University of Szeged', desc: 'Pharmaceutical chemistry and the formulation of medicinal products at the Institute of Pharmaceutical Technology.' },
            { site: 'ELI Facility, Szeged', desc: 'One of the world\'s highest-intensity laser facilities; introduction to laser chemistry.' },
            { site: 'University of Pécs', desc: 'Chemistry of emerging diseases, mining extraction, and nuclear chemistry.' },
            { site: 'Eger University', desc: 'Biochemistry of fermentation and natural microfluidics in wine production.' },
            { site: 'Pannonhalma Abbey', desc: 'Chemical ecology and the historical contributions of monastic institutions to European science education.' }
          ].map(item => (
            <li style="border-left: 3px solid var(--accent); padding-left: 20px;">
              <strong style="color: var(--text); display: block; margin-bottom: 4px;">{item.site}</strong>
              {item.desc}
            </li>
          ))}
        </ul>

        <p>The program gave me a broader sense of where analytical chemistry sits within the larger scientific economy and connected me to collaborators I've continued to work with on the DMTS cyanide antidote program.</p>
      </div>
    </div>
  </div>

  <script>
    const cards = document.querySelectorAll('.training-card');
    const modals = document.querySelectorAll('.training-modal');
    const closeBtns = document.querySelectorAll('.close-modal');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const modalId = card.getAttribute('data-modal');
        const modal = document.getElementById(modalId);
        if (modal) {
          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    const closeModal = (modal) => {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };

    closeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        closeModal(btn.closest('.training-modal'));
      });
    });

    modals.forEach(modal => {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal(modal);
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        modals.forEach(modal => {
          if (modal.classList.contains('active')) closeModal(modal);
        });
      }
    });

    // Typewriter Logic: Just the dots
    const typeTarget = document.getElementById('typewriter-text');
    const cursor = document.querySelector('.typewriter-cursor');
    const textToType = "...";
    let charIndex = 0;
    let isTyping = false;

    function typeChar() {
      if (charIndex < textToType.length) {
        isTyping = true;
        cursor.classList.add('typing');
        typeTarget.textContent += textToType.charAt(charIndex);
        charIndex++;
        setTimeout(typeChar, 400); // Slower, intentional dot typing
      } else {
        isTyping = false;
        cursor.classList.remove('typing');
        setTimeout(resetTypewriter, 2000);
      }
    }

    function resetTypewriter() {
      typeTarget.textContent = '';
      charIndex = 0;
      setTimeout(typeChar, 500);
    }

    const typewriterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !isTyping && charIndex === 0) {
          setTimeout(typeChar, 500);
        }
      });
    }, { threshold: 0.5 });

    if (typeTarget) {
      typewriterObserver.observe(typeTarget);
    }
  </script>
    <!-- Subheading: Teaching & Mentorship -->
    <div style="display: flex; align-items: center; gap: 12px; margin: 80px 0 40px;">
      <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; fill: var(--accent); filter: drop-shadow(0 0 3px var(--accent)) drop-shadow(0 0 8px var(--accent)); flex-shrink: 0;">
