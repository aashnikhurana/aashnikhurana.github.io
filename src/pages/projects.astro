---
import Base from '@/layouts/Base.astro'
---

<Base
  title="Projects"
  description="Projects — Aashni Khurana."
>

  <div style="max-width: 960px; margin: 0 auto; padding: 80px 7vw 120px;">

    <h1 style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(40px, 6vw, 64px); color: var(--text); line-height: 1.1; margin: 0 0 32px;">
      Projects
    </h1>

    <p style="font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 24px; color: var(--text-muted); margin: 0 0 40px;">
      Coming soon.
    </p>

    <a
      href="/"
      style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 300ms cubic-bezier(0.2, 0, 0, 1);"
      class="back-link"
    >
      &larr; Home
    </a>

  </div>

</Base>

<style>
  .back-link:hover {
    color: var(--accent) !important;
  }
</style>
