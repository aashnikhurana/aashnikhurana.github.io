---
import Base from './Base.astro'

interface Props {
  title: string
  subtitle: string
  tags: string[]
  year: string
  description?: string
  prevStudy?: { title: string; href: string }
  nextStudy?: { title: string; href: string }
}

const {
  title,
  subtitle,
  tags,
  year,
  description,
  prevStudy,
  nextStudy,
} = Astro.props

const metaDescription = description ?? `${title} — ${subtitle}`
---

<Base title={title} description={metaDescription}>
  <article style="max-width: 1080px; margin: 0 auto; padding: 80px 0 120px;">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" style="margin-bottom: 48px;">
      <a
        href="/#research"
        style="font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color 300ms cubic-bezier(0.2, 0, 0, 1);"
        class="breadcrumb-link"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle; margin-right: 4px; position: relative; top: -1px;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg> Research
      </a>
    </nav>

    <!-- Header -->
    <header style="margin-bottom: 48px;">
      <h1 class="cs-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(32px, 5vw, 56px); color: var(--text); line-height: 1.1; margin: 0 0 16px;">
        {title}
      </h1>
      <p class="cs-subtitle" style="font-family: Inter, sans-serif; font-style: italic; font-size: 18px; color: var(--text-muted); margin: 0 0 20px; line-height: 1.5;">
        {subtitle}
      </p>
      <div class="cs-tags" style="display: flex; flex-wrap: wrap; gap: 8px 16px; font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent);">
        {tags.map((tag, idx) => (
          <>
            <span>{tag}</span>
            {idx < tags.length - 1 && <span style="opacity: 0.3;">&middot;</span>}
          </>
        ))}
      </div>
    </header>

    <hr style="border: none; border-top: 1px solid var(--rule); margin: 0 0 48px;" />

    <!-- Two-column: prose + sidebar -->
    <div class="cs-grid">

      <!-- Main prose -->
      <div class="cs-prose" style="max-width: 720px;">
        <slot />
      </div>

      <!-- Sidebar -->
      <aside class="cs-sidebar">
        <slot name="sidebar" />
      </aside>

    </div>

    <!-- Pagination -->
    {(prevStudy || nextStudy) && (
      <>
        <hr style="border: none; border-top: 1px solid var(--rule); margin: 80px 0 40px;" />
        <nav
          class="case-study-pagination"
          style="display: flex; justify-content: space-between; align-items: center; gap: 24px;"
          aria-label="Case study navigation"
        >
          <div style="flex: 1;">
            {prevStudy && (
              <a
                href={prevStudy.href}
                class="pagination-link"
                style="display: flex; flex-direction: column; text-decoration: none; color: var(--text-dim); transition: color 0.3s ease; gap: 8px;"
              >
                <span class="pagination-label" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: white;">&larr; PREVIOUS</span>
                <span class="pagination-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 20px;">{prevStudy.title}</span>
              </a>
            )}
          </div>
          <div style="flex: 1; text-align: right;">
            {nextStudy && (
              <a
                href={nextStudy.href}
                class="pagination-link"
                style="display: flex; flex-direction: column; align-items: flex-end; text-decoration: none; color: var(--text-dim); transition: color 0.3s ease; gap: 8px;"
              >
                <span class="pagination-label" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: white;">NEXT &rarr;</span>
                <span class="pagination-title" style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 20px;">{nextStudy.title}</span>
              </a>
            )}
          </div>
        </nav>
      </>
    )}

  </article>
</Base>

<style>
  /* Prose typography */
  .cs-prose :global(p) {
    font-family: Inter, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 32px;
  }

  .cs-prose :global(a) {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    text-decoration-color: var(--rule);
    transition: all 300ms var(--easing);
  }

  .cs-prose :global(a:hover) {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .cs-prose :global(h2) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
    font-size: 28px;
    color: var(--text);
    margin-top: 48px;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .cs-prose :global(h3) {
    font-family: Inter, sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: var(--text);
    letter-spacing: 0.05em;
    margin-top: 40px;
    margin-bottom: 16px;
  }

  /* Image + caption */
  .cs-prose :global(.cs-image-wrap) {
    margin: 40px 0 48px;
    text-align: center;
  }

  .cs-prose :global(.cs-image-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin: 40px 0 48px;
  }

  .cs-prose :global(.cs-image-grid .cs-image-wrap) {
    margin: 0;
  }

  @media (max-width: 768px) {
    .cs-prose :global(.cs-image-grid) {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .cs-prose :global(.cs-image-wrap img) {
    max-width: 80%;
    width: auto;
    height: auto;
    border-radius: 2px;
    display: block;
    margin: 0 auto;
  }

  /* Force full width on grid images */
  .cs-prose :global(.cs-image-grid .cs-image-wrap img) {
    max-width: 100%;
  }

  .cs-prose :global(.cs-caption) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin: 16px 0 0;
    text-transform: none; /* Removed all-caps */
    text-align: center;
    line-height: 1.5;
  }

  /* Sidebar typography */
  .cs-sidebar :global(.sidebar-block) {
    margin-bottom: 32px;
  }

  .cs-sidebar :global(.sidebar-logo) {
    width: 100px;
    height: auto;
    display: block;
    opacity: 0.6;
    margin-bottom: 12px;
  }

  .cs-sidebar :global(.sidebar-logo.ucsd-health) {
    width: 200px;
    aspect-ratio: 4 / 1;
    object-fit: cover;
    object-position: 25% center; /* Shift slightly right to crop left space */
    transform: scale(1.1); /* Zoom in a bit more */
  }

  .cs-sidebar :global(.sidebar-label) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 8px;
    display: block;
  }

  .cs-sidebar :global(.sidebar-value) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-muted);
    display: block;
  }

  .cs-sidebar :global(.sidebar-item) {
    display: block;
    margin-bottom: 12px;
  }

  .cs-sidebar :global(.sidebar-item:last-child) {
    margin-bottom: 0;
  }

  .cs-sidebar :global(.sidebar-link) {
    color: inherit;
    text-decoration: none;
    transition: color 300ms cubic-bezier(0.2, 0, 0, 1);
  }

  .cs-sidebar :global(.sidebar-link:hover) {
    color: var(--accent) !important;
  }

  .cs-sidebar :global(.sidebar-link-icon) {
    font-size: 1.2em;
    margin-left: 4px;
    vertical-align: baseline;
    line-height: 0;
    display: inline-block;
  }

  /* Hover states */
  .breadcrumb-link:hover {
    color: var(--accent) !important;
  }

  .pagination-link:hover {
    color: var(--accent) !important;
  }

  .cs-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 80px;
    align-items: start;
  }

  /* Mobile: sidebar below prose */
  @media (max-width: 1024px) {
    article {
      display: flex !important;
      flex-direction: column !important;
      padding-left: 7vw !important;
      padding-right: 7vw !important;
      padding-top: 64px !important;
    }

    nav[aria-label="Breadcrumb"] { order: -5 !important; margin-bottom: 24px !important; }
    header { order: -4 !important; margin-bottom: 24px !important; }

    .cs-grid {
      display: contents !important;
    }

    .cs-sidebar, .cs-sidebar > :global(div) {
      display: contents !important;
    }

    /* All sidebar blocks go ABOVE prose together */
    .cs-sidebar :global(.sidebar-block:not(.techniques-block)) {
      display: block !important;
      order: -3 !important;
      margin-bottom: 24px !important;
      border-top: none !important;
      padding-top: 0 !important;
    }

    /* Main header divider stays ABOVE prose but BELOW all meta */
    hr[style*="margin: 0 0 48px"] { 
      display: block !important;
      order: -2 !important; 
      margin-top: 24px !important;
      margin-bottom: 32px !important; 
    }

    /* Prose stays in MIDDLE */
    .cs-prose {
      display: block !important;
      order: -1 !important;
      margin-top: 0 !important;
      margin-bottom: 48px !important;
    }

    /* Pagination stays at the very bottom */
    hr[style*="margin: 80px 0 40px"] { order: 2 !important; margin: 40px 0 24px !important; }
    nav[aria-label="Case study navigation"] { order: 3 !important; margin-bottom: 80px !important; }

    .cs-title {
      font-size: 28px !important;
      margin-bottom: 10px !important;
    }

    .cs-subtitle {
      font-size: 14px !important;
      margin-bottom: 12px !important;
    }

    .cs-tags {
      font-size: 9px !important;
      gap: 4px 10px !important;
    }

    .cs-sidebar :global(.sidebar-label) {
      font-size: 11px !important;
      margin-bottom: 6px !important;
    }

    .cs-sidebar :global(.sidebar-value) {
      font-size: 13px !important;
    }

    .cs-sidebar :global(.sidebar-logo) {
      width: 70px !important;
      margin-bottom: 16px !important;
    }

    .cs-sidebar :global(.sidebar-logo.ucsd-health) {
      width: 70px !important;
      margin-bottom: 16px !important;
    }

    .cs-sidebar :global(.techniques-block) {
      display: none !important;
    }

    .cs-prose :global(.cs-caption) {
      font-size: 11px !important;
      margin-top: 12px !important;
      line-height: 1.4 !important;
    }

    .cs-prose :global(p) {
      font-size: 13px !important;
      line-height: 1.6 !important;
      margin-bottom: 24px !important;
    }

    .cs-prose :global(h2) {
      font-size: 24px !important;
      margin-top: 32px !important;
      margin-bottom: 16px !important;
    }

    /* Homogenize pagination on mobile */
    nav[aria-label="Case study navigation"] {
      flex-direction: row !important;
      justify-content: flex-end !important; /* Push everything to right */
      align-items: center !important;
      gap: 16px !important;
      padding-bottom: 24px !important;
    }

    nav[aria-label="Case study navigation"] div {
      flex: 0 1 auto !important;
    }

    /* If both exist, keep Previous on left */
    nav[aria-label="Case study navigation"] div:first-child {
      margin-right: auto !important;
    }

    .pagination-link {
      align-items: flex-start !important;
    }

    .pagination-title {
      display: none !important;
    }

    .pagination-label {
      color: white !important;
      font-size: 11px !important;
      letter-spacing: 0.2em !important;
    }

    hr[style*="margin: 80px 0 40px"] {
      margin-top: 24px !important;
      margin-bottom: 16px !important;
    }

    /* Reduce black area at bottom */
    footer {
      padding-top: 24px !important;
      padding-bottom: 24px !important;
    }
  }
</style>
